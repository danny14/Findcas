@using Microsoft.Extensions.Localization
@using Findcas.Web.Client.Resources
@using Microsoft.AspNetCore.Components.Authorization
@inject IStringLocalizer<App> L
@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">@L["AppName"]</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> @L["Nav_Home"]
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="fincas/nueva">
                <span class="bi bi-house-add-fill-nav-menu" aria-hidden="true"></span> @L["Nav_AddProperty"]
            </NavLink>
        </div>

        @* --- MENÚ DE RESERVAS (SOLO PARA USUARIOS LOGUEADOS) --- *@
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    @* Ruta estricta en inglés, texto visible en español (o puedes usar @L["Nav_MyReservations"] si lo agregas a tus recursos) *@
                    <NavLink class="nav-link" href="my-reservations">
                        <span class="bi bi-calendar-check-fill-nav-menu" aria-hidden="true"></span> Mis Reservas
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        @* --- MENÚ DE IDIOMAS --- *@
        <div class="nav-item px-3">
            <MudMenu Label="@L["Language"]"
                     StartIcon="@Icons.Material.Filled.Language"
                     EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                     Color="Color.Inherit"
                     Variant="Variant.Text"
                     Class="nav-link mud-nav-link-custom">
                <MudMenuItem OnClick="@(() => ChangeLanguage("es"))">Español</MudMenuItem>
                <MudMenuItem OnClick="@(() => ChangeLanguage("en"))">English</MudMenuItem>
            </MudMenu>
        </div>
    </nav>
</div>

@code {
    private void ChangeLanguage(string culture)
    {
        var uri = new Uri(Navigation.Uri).GetComponents(UriComponents.PathAndQuery, UriFormat.Unescaped);
        var query = $"/Culture/Set?culture={culture}&redirectUri={uri}";
        Navigation.NavigateTo(query, forceLoad: true);
    }
}

<style>
    .mud-nav-link-custom {
        color: rgba(255,255,255,0.5) !important;
        width: 100%;
        justify-content: start !important;
        padding-left: 16px !important;
    }

        .mud-nav-link-custom:hover {
            color: white !important;
        }
</style>