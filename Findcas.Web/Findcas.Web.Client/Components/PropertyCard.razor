@using Findcas.Domain.Entities
@using MudBlazor
@inject NavigationManager Navigation

<MudPaper Elevation="0" Class="property-card" @onclick="GoToDetails">
    @* Contenedor de la imagen con bordes redondeados solo arriba *@
    <div class="image-container">
        <MudImage Src="@GetImageUrl()" Alt="@Property.Name" ObjectFit="ObjectFit.Cover" Class="property-image" />
    </div>

    <div class="pa-4">
        @* Nombre de la finca *@
        <MudText Typo="Typo.subtitle1" Class="font-weight-bold text-truncate property-title mb-1">
            @Property.Name
        </MudText>

        @* Ubicación con icono gris *@
        <div class="d-flex align-center mb-3 text-muted">
            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-1" />
            <MudText Typo="Typo.body2" Class="text-truncate">
                @Property.City, @Property.Department
            </MudText>
        </div>

        @* Características (Camas, Baños, Personas) alineadas al diseño *@
        <MudStack Row="true" Spacing="3" Class="mb-3">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Bed" Size="Size.Small" Class="mr-1 text-muted" />
                <MudText Typo="Typo.body2" Class="font-weight-medium">@Property.Bedrooms</MudText>
            </div>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Bathtub" Size="Size.Small" Class="mr-1 text-muted" />
                <MudText Typo="Typo.body2" Class="font-weight-medium">@Property.Bathrooms</MudText>
            </div>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" Class="mr-1 text-muted" />
                <MudText Typo="Typo.body2" Class="font-weight-medium">@Property.MaxGuests</MudText>
            </div>
        </MudStack>

        @* Precio resaltado en verde (Como en el mockup de Stitch) *@
        <MudText Typo="Typo.body2" Class="price-text">
            <span class="text-muted font-weight-regular">Desde</span> $@Property.PricePerNight.ToString("N0") <span class="text-muted font-weight-regular">/ noche</span>
        </MudText>
    </div>
</MudPaper>

@code {
    [Parameter]
    public Property Property { get; set; } = null!;

    private string GetImageUrl()
    {
        return Property?.Images?.FirstOrDefault()?.Url
            ?? "https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&q=80&w=500";
    }

    private void GoToDetails()
    {
        Navigation.NavigateTo($"/finca/{Property.Id}");
    }
}

<style>
    /* Estilos estructurales y de animación para la tarjeta */
    .property-card {
        cursor: pointer;
        border-radius: 20px !important; /* Curva pronunciada como en el diseño */
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        overflow: hidden; /* Evita que la imagen se salga de los bordes curvos */
        border: 1px solid #EAEAEA;
        background-color: #FFFFFF;
    }

        /* Efecto hover suave (levanta la tarjeta ligeramente) */
        .property-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.08) !important;
        }

    .image-container {
        width: 100%;
        height: 220px; /* Altura fija para mantener consistencia en la grilla */
        overflow: hidden;
    }

    .property-image {
        width: 100%;
        height: 100%;
    }

    /* Colores extraídos de la propuesta visual */
    .property-title {
        color: #2C2C2C;
    }

    .text-muted {
        color: #757575 !important;
    }

    .price-text {
        color: #79A15F !important; /* El tono verde característico de tu diseño */
        font-weight: 700;
    }
</style>