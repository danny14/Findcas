@page "/register"
@using Findcas.Web.Client.Models
@using Findcas.Web.Client.Services
@inject AuthHttpClient AuthClient
@inject NavigationManager NavManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8 rounded-lg">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6 font-weight-bold">Crear Cuenta</MudText>

        <EditForm Model="@_registerModel" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />

            <MudStack Spacing="4">
                <MudTextField @bind-Value="_registerModel.Email"
                              Label="Correo Electrónico"
                              Variant="Variant.Outlined"
                              For="@(() => _registerModel.Email)" />

                <MudTextField @bind-Value="_registerModel.Password"
                              Label="Contraseña"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              For="@(() => _registerModel.Password)" />

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-4" Disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Registrando...</MudText>
                    }
                    else
                    {
                        <MudText>Registrarse</MudText>
                    }
                </MudButton>
            </MudStack>
        </EditForm>

        <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-6">
            ¿Ya tienes una cuenta? <MudLink Href="/login">Inicia sesión aquí</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private RegisterDto _registerModel = new();
    private bool _isLoading = false;

    private async Task HandleRegister()
    {
        _isLoading = true;

        var result = await AuthClient.RegisterAsync(_registerModel);

        if (result == "OK")
        {
            Snackbar.Add("¡Cuenta creada exitosamente! Por favor inicia sesión.", Severity.Success);
            NavManager.NavigateTo("/login");
        }
        else
        {
            Snackbar.Add(result, Severity.Error);
        }

        _isLoading = false;
    }
}