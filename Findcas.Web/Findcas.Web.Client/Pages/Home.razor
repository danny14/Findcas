@page "/"
@using Findcas.Domain.Entities
@using Findcas.Application.Interfaces
@inject IPropertyService PropertyService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-10 mb-10">
    @* Títulos principales con un toque más elegante *@
    <MudText Typo="Typo.h3" Class="font-weight-bold mb-2">Explora Fincas</MudText>
    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-10">
        Encuentra el lugar perfecto para tu próximo descanso
    </MudText>
    
    @* --- BARRA DE BÚSQUEDA Y FILTRO INTEGRADA (TIPO AIRBNB) CORREGIDA --- *@
    <MudPaper Elevation="1" Class="pa-4 py-md-2 px-md-6 responsive-search-bar mb-12" Outlined="true">
        <MudGrid Spacing="2" Class="align-center">
            <MudItem xs="12" md="4">
                <MudAutocomplete T="string"
                                 Label="Ubicación"
                                 Placeholder="Ej. Cali, Valle del Cauca"
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.LocationOn"
                                 Rounded="true"
                                 SearchFunc="@SearchLocationAsync"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="true"
                                 CoerceValue="false" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudDateRangePicker Label="Fechas" Variant="Variant.Outlined" Color="Color.Primary" Rounded="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudNumericField T="int" Label="Huéspedes" Min="1" Value="2" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Groups" Rounded="true" />
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center justify-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Search" Class="rounded-pill px-6 py-3" FullWidth="true">
                    Buscar
                </MudButton>
                @* Ocultamos el botón de filtros extra en móvil para ahorrar espacio *@
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudIconButton Icon="@Icons.Material.Filled.Tune" Color="Color.Primary" Class="ml-2" />
                </MudHidden>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* Grilla de Fincas - Asumimos que la lógica de carga de _properties ya existe y funciona *@
    @if (_properties == null)
    {
        <MudStack AlignItems="AlignItems.Center" Class="mt-10">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.h6">Cargando fincas disponibles...</MudText>
        </MudStack>
    }
    else if (!_properties.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mt-10">Lo sentimos, no hay fincas disponibles en este momento. ¡Vuelve pronto!</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var property in _properties)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <PropertyCard Property="property" />
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private IEnumerable<Property>? _properties;

    protected override async Task OnInitializedAsync()
    {
        // Asumimos que esta llamada ya existe y funciona
        _properties = await PropertyService.GetAllPropertiesAsync();
    }

    private async Task<IEnumerable<string>> SearchLocationAsync(string value, CancellationToken token)
    {
        return await PropertyService.SearchColombiaCitiesAsync(value);
    }
}

<style>
    /* 1. Mobile First: Bordes redondeados suaves para celular */
    .responsive-search-bar {
        border-radius: 16px !important;
    }

    /* 2. Desktop: Cuando la pantalla es ancha (md = 960px o más), usamos forma de píldora */
    @@media(min-width: 960px) {
        .responsive-search-bar

    {
        border-radius: 9999px !important;
    }

    }
</style>